---
import { generateBreadcrumbs } from "@/lib/navigation";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const breadcrumbs = generateBreadcrumbs(pathname);
---

{
  breadcrumbs.length > 1 && (
    <nav
      aria-label="パンくずリスト"
      class="mx-auto w-full max-w-5xl px-4 pt-6 md:px-6 mb-8"
    >
      <ol class="flex items-center gap-2 text-sm fg-muted">
        {breadcrumbs.map((item, index) => (
          <li class="flex items-center gap-2">
            {index > 0 && <span class="fg-ghost">/</span>}
            {item.isCurrent ? (
              <span class="font-semibold fg-base">{item.title}</span>
            ) : (
              <a href={item.path} class="link">
                {item.title}
              </a>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )
}
