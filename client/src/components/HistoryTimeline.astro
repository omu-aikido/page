---
interface Item {
  year: string;
  description: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<dl class="space-y-0">
  {
    items.map((item) => (
      <>
        <dt class="text-sm font-semibold text-zinc-500 dark:text-zinc-400">
          {item.year}
        </dt>
        <dd class="mt-2 text-base text-zinc-700 dark:text-zinc-300 m-0">
          {item.description}
        </dd>
      </>
    ))
  }
</dl>
