---
interface ScheduleItem {
  day: string;
  location: string;
  time: string;
}

interface Props {
  items: ScheduleItem[];
}

const { items } = Astro.props;
---

<dl class="space-y-0">
  {
    items.map((item) => (
      <div class="row-soft">
        <dt class="text-base font-bold text-zinc-900 dark:text-zinc-100">
          {item.day}
        </dt>
        <dd class="text-zinc-700 dark:text-zinc-300 m-0">
          <p class="text-base m-0">{item.location}</p>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 m-0">
            {item.time}
          </p>
        </dd>
      </div>
    ))
  }
</dl>
