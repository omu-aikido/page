---
import { navlinks } from "@/lib/navigation";

const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path;
---

<button
  id="open-sidebar"
  class="i-ri:menu-line text-2xl transition hover:(cursor-pointer fg-accent)"
  aria-label="Open Sidebar"></button>

<dialog
  id="sidebar"
  class="w-80 max-w-full rounded-none border-0 bg-base fg-base"
>
  <div class="min-h-100dvh m-4 flex flex-col">
    <button
      id="close-sidebar"
      class="i-ri:close-line mb-2 ml-auto text-3xl transition hover:(fg-accent cursor-pointer)"
      aria-label="Close Sidebar"></button>

    <nav class="mx-2 flex-1 space-y-1">
      {
        navlinks.map((parent) => {
          return (
            <stack gap-2>
              <a
                href={parent.path}
                transition:name={`nav-${parent.path.replaceAll("/", "-") || "home"}`}
                class={`px-2 py-1 rounded-sm ${isActive(parent.path) ? "accent" : "hover:muted"}`}
              >
                {parent.title}
              </a>
              {parent.children &&
                parent.children.map((child) => {
                  return (
                    <>
                      <a
                        href={child.path}
                        transition:name={`nav-${child.path.replaceAll("/", "-")}`}
                        class={`px-2 py-1 rounded-sm ${isActive(child.path) ? "accent" : "hover:muted"}`}
                      >
                        {child.title}
                      </a>

                      {child.children &&
                        child.children.map((grandchild) => {
                          return (
                            <a
                              href={grandchild.path}
                              transition:name={`nav-${grandchild.path.replaceAll("/", "-")}`}
                              class={`pl-6 px-2 py-1 rounded-sm ${isActive(grandchild.path) ? "accent" : "hover:muted"}`}
                            >
                              {grandchild.title}
                            </a>
                          );
                        })}
                    </>
                  );
                })}
            </stack>
          );
        })
      }
    </nav>
  </div>
</dialog>

<style>
  dialog#sidebar {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: auto;
    min-height: 100dvh;
  }

  dialog#sidebar::backdrop {
    background: rgba(0, 0, 0, 0.5);
    transition: opacity 0.2s ease;
    @apply backdrop-blur-xs;
  }

  dialog#sidebar[open] {
    animation: slide-in 0.2s ease-out;
  }

  @keyframes slide-in {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }

  .nav-link {
    @apply block w-full px-4 py-2 my-1.5 rounded-sm transition;
  }

  .nav-link--parent {
    @apply text-base font-bold hover:(bg-zinc-200 dark:bg-zinc-800);
  }

  .nav-link--child {
    @apply text-sm font-semibold hover:(bg-zinc-200 dark:bg-zinc-800);
  }

  .nav-link--grandchild {
    @apply text-sm font-medium hover:(bg-zinc-200 dark:bg-zinc-800);
  }

  .nav-link--active {
    @apply bg-brand-600 text-white font-semibold;
  }

  .nav-children {
    @apply space-y-1 mt-1;
  }

  .nav-children--indent {
    @apply ml-4;
  }

  .nav-grandchildren {
    @apply space-y-1 mt-1 ml-4;
  }
</style>

<script>
  function initSidebar() {
    const dialog = document.getElementById("sidebar") as HTMLDialogElement;
    const openBtn = document.getElementById("open-sidebar");
    const closeBtn = document.getElementById("close-sidebar");

    if (dialog?.open) {
      dialog.close();
    }

    openBtn?.addEventListener("click", () => {
      dialog?.showModal();
    });

    closeBtn?.addEventListener("click", () => {
      dialog?.close();
    });

    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }

  document.addEventListener("astro:page-load", initSidebar);

  document.addEventListener("keydown", (event) => {
    const dialog = document.getElementById("sidebar") as HTMLDialogElement;
    if (event.key === "Escape" && dialog?.open) {
      dialog.close();
    }
  });

  document.addEventListener("astro:after-swap", () => {
    const dialog = document.getElementById("sidebar") as HTMLDialogElement;
    if (dialog?.open) {
      dialog.close();
    }
  });
</script>
