---
import ContactForm from "@/components/contactForm.vue";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="お問い合わせ"
  description="大阪大学合気道部へのお問い合わせフォームです。"
>
  <section class="container-page">
    <div class="mb-4" transition:name="contact-cta">
      <h1 class="text-heading text-3xl font-bold">お問い合わせ</h1>
      <p class="text-body mt-2">
        見学・体験・入部に関するご質問など、お気軽にご連絡ください。
      </p>
      <p class="mt-2 text-body">
        <a href="https://marshmallow-qa.com/8f2ofku54h476je" class="link">
          マシュマロ
        </a>
        では匿名質問も受け付けています！
      </p>
    </div>

    <ContactForm client:only="vue" />
  </section>
</Layout>
