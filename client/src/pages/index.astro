---
import SiteGuideBento from "@/components/SiteGuideBento.astro";
import PhotoSlideshow from "@/components/PhotoSlideshow.astro";

import Layout from "@/layouts/Layout.astro";

// Import hero images
import a61baa65 from "@/assets/hero/a61baa65.jpg";
import a899c25a from "@/assets/hero/a899c25a.jpg";
import a2007d4a from "@/assets/hero/a2007d4a.jpg";

const slideImages = [
  {
    src: a899c25a,
    alt: "2025年度集合写真",
  },
  { src: a61baa65, alt: "2026年度の新歓の様子です" },
  { src: a2007d4a, alt: "普段の稽古の様子" },
];
---

<Layout title="トップ" description="大阪公立大学合氣道部の公式ホームページです">
  <section
    class="stack gap-4 relative pt-12"
    transition:name="home-hero"
    id="hero-section"
  >
    <h1 class="h1">
      大阪公立大学<br class="sm:hidden" />合氣道部
    </h1>
    <p class="max-w-2/3 leading-relaxed fg-base">
      大阪公立大学合氣道部は、森之宮キャンパス・中百舌鳥キャンパス・杉本キャンパスで活動する、体育会所属の合気道団体です。
    </p>
    <a href="/about" class="button accent px-4 py-2 w-fit">活動について→</a>

    <div id="hero-accent-bg" aria-hidden="true"></div>
  </section>

  <section class="py-8">
    <PhotoSlideshow images={slideImages} />
  </section>

  <section>
    <h2 class="h2 mb-4">探索する</h2>
    <SiteGuideBento />
  </section>
</Layout>

<style is:inline>
  #hero-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(37, 99, 235, 0.3),
      transparent
    );
  }

  #hero-accent-bg {
    position: absolute;
    top: -30%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 50%,
      rgba(37, 99, 235, 0.08),
      transparent 70%
    );
    pointer-events: none;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    #hero-accent-bg {
      width: min(400px, 70vw);
      height: min(400px, 70vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #hero-accent-bg {
      animation: none;
    }
  }
</style>
