    "deploy": "astro build && wrangler deploy --project-name=omu-aikido-page --branch=preview",
    "preview": "astro build && wrangler pages dev",
    "astro": "astro",
    "cf-typegen": "wrangler types",
    "prebuild": "bun run cf-typegen",
    "format": "bunx oxfmt ."
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.2",
    "@astrojs/sitemap": "3.7.1",
    "@astrojs/vue": "6.0.1",
    "@headlessui/vue": "1.7.23",
    "astro": "6.0.5",
    "astro-llms-generate": "1.3.3",
    "hono": "4.12.8",
    "sharp": "0.34.5",
    "ts-ics": "2.4.3",
    "vite": "8.0.0",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "1.2.3",
    "@types/node": "24.12.0",
    "@unocss/astro": "66.6.6",
    "@unocss/reset": "66.6.6",
    "concurrently": "9.2.1",
    "unocss": "66.6.6",
    "wrangler": "4.71.0"
  },
  "packageManager": "bun@1.3.1"
