---
import Loading from "@/components/ui/loadings.astro"

const {
  src,
  class: iframeClass = "iframe-base",
  loading = "lazy",
  allowFullScreen = true,
  title = "Embedded content",
} = Astro.props as any
---

<div class="iframe-wrapper">
  <div class="loading-overlay" aria-hidden="true">
    <Loading class="loading-icon" size={48} title="読み込み中" />
  </div>
  <iframe
    src={src}
    title={title}
    loading={loading}
    class={`relative z-10 ${iframeClass}`}
    {...allowFullScreen ? { allowfullscreen: true } : {}}></iframe>
</div>
