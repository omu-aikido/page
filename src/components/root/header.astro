---
import { Image } from "astro:assets";
import Sidebar from "@/components/component/sidebar.vue";
---

<header class="sticky top-0 backdrop-blur-3xl z-2000000000">
  <div
    aria-label="Global"
    class="mx-auto flex max-w-7xl items-center justify-between p-5 lg:px-8"
  >
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">大阪公立大学合氣道部</span>
        <Image
          alt=""
          src="/favicon.svg"
          class="h-10 w-auto rounded-full"
          width={40}
          height={40}
          loading="eager"
        />
      </a>
    </div>

    <div class="flex lg:hidden">
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-controls="mobile-menu-root"
        aria-expanded="false"
        class="mobile-menu-btn"
        onclick="window.dispatchEvent(new CustomEvent('sidebar:open'))"
      >
        <span class="sr-only">リンクメニューを開く</span>
        <div class="i-heroicons:bars-3-16-solid h-6 w-6" />
      </button>
    </div>
    <nav
      class="hidden lg:flex lg:gap-x-12 [&_a]:text-md"
    >
      <a href="/" class="nav-link">ホーム</a>
      <a href="/about" class="nav-link">合氣道部について</a>
      <a href="/calendar" class="nav-link">稽古予定</a>
      <a href="/access" class="nav-link">アクセス</a>
    </nav>

    <nav class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a
        href="/support"
        class="nav-link-cta"
      >
        応援する<span aria-hidden="true">&rarr;</span>
      </a>
    </nav>
  </div>
  <Sidebar client:idle />
</header>
