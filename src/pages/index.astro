---
import aikidoImage from "@/assets/84DABC3E-78F6-4FAC-B2EB-F98F5DDDFC15.webp"
import NavCard from "@/components/ui/navcard.astro"
import Layout from "@/layouts/Layout.astro"
import { Image } from "astro:assets"
---

<Layout title="トップ" description="大阪公立大学合氣道部の公式ホームページです">
  <section class="hero-section">
    <div class="text-center">
      <h1 class="hero-title">大阪公立大学合氣道部</h1>
      <p class="hero-subtitle">大阪公立大学合氣道部は、大阪公立大学中百舌鳥キャンパス、杉本キャンパスで活動する、体育会所属の合気道団体です。</p>
      <a href="/about" aria-label="私たちについて" class="btn-primary-inline">もっと知る</a>
    </div>
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-gradient"></div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="mb-8 flex items-center justify-between">
      <a href="/about/aikido" class="link-section">
        <h2 class="text-3xl font-bold text-heading">合気道を知る</h2>
      </a>
    </div>
    <div class="card-feature">
      <div class="grid items-center gap-8 md:grid-cols-2">
        <div class="[&_p]:mb-4 [&_p]:text-body">
          <h3 class="mb-4 text-2xl font-semibold text-heading">合気道とは</h3>
          <p>合気道は、開祖・植芝盛平翁が創始した現代武道です。<br/>相手と強弱を競わず、入身と転換の体捌きと呼吸力から生まれる技によって心身の錬成図ります。</p>
          <p>試合や競技は行わず、お互いに切磋琢磨し合って稽古を積み重ねることを目的としています。</p>
          <a title="合気道についてもっと詳しく知る" href="/about/aikido" class="btn-primary-inline">もっと詳しく</a>
        </div>
        <div class="text-center">
          <Image src={aikidoImage} alt="座技呼吸法を指導する様子" loading="lazy" class="mx-auto flex h-56 w-56 items-center justify-center rounded-full bg-surface-tertiary dark:bg-border-inverse" />
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <h2 class="text-section-title">サイト案内</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <NavCard title="活動場所" icon="map-pin" desc="稽古場所へのアクセス" link="access" />
      <NavCard title="活動予定" icon="calendar" desc="活動予定の確認" link="calendar" />
      <NavCard title="応援する" icon="heart" desc="合氣道部を応援いませんか？" link="support" />
      <NavCard title="リンク集" icon="link" desc="関連団体サイトへのリンク" link="about/links" />
    </div>

    <section class="my-16">
      <div class="card-cta">
        <h2 class="mb-4 text-3xl font-bold text-heading">お気軽にお問い合わせください</h2>
        <p class="mx-auto mb-8 max-w-2xl text-lg text-body">見学・体験・入部に関するご質問など、お待ちしています</p>
        <a href="/contact" class="btn-primary-inline">お問い合わせ</a>
      </div>
    </section>
  </section>
</Layout>
